{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "editor",
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  }
}
