{
  "_comment": "Voice profile config. TTS agent reads this at start of every run. Edit manually to change default engine or fallback chain.",

  "default_engine": "coqui_xtts_v2",

  "clone_ids": {
    "coqui_xtts_v2": null,
    "fish_speech": null,
    "style_tts_2": null,
    "piper": null,
    "elevenlabs": null
  },

  "fallback_chain": ["coqui_xtts_v2"],

  "voice_switching_policy": "explicit_user_approval_required",

  "voice_sample_path": null,

  "commercial_use": false,

  "language_default": "en-US",

  "loudness_target_lufs": -16,

  "engines": {
    "coqui_xtts_v2": {
      "role": "primary_testing",
      "license": "CPML (non-commercial)",
      "hardware": "GPU",
      "voice_cloning": true,
      "install": "pip install TTS==0.22.0 (Python 3.11 venv via uv)",
      "notes": "Pin transformers>=4.33,<4.41. Set COQUI_TOS_AGREED=1 and MPLBACKEND=Agg."
    },
    "fish_speech": {
      "role": "license_upgrade_pre_monetization",
      "license": "MIT-ish",
      "hardware": "GPU",
      "voice_cloning": true,
      "install": "github.com/fishaudio/fish-speech"
    },
    "style_tts_2": {
      "role": "quality_option",
      "license": "MIT",
      "hardware": "GPU",
      "voice_cloning": true,
      "install": "github.com/yl4579/StyleTTS2"
    },
    "piper": {
      "role": "cpu_fallback",
      "license": "MIT",
      "hardware": "CPU",
      "voice_cloning": false,
      "install": "pip install piper-tts",
      "notes": "NO voice cloning. Switching to Piper changes the voice — Law 7 requires explicit user approval."
    },
    "elevenlabs": {
      "role": "monetization_upgrade",
      "license": "commercial (paid)",
      "hardware": "API",
      "voice_cloning": true,
      "install": "pip install elevenlabs"
    }
  }
}
