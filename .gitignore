# .gitignore

# Video/audio files — too large for GitHub, stored on Google Drive
*.mp4
*.wav
*.mp3
*.mov
*.mkv
*.avi
*.flv

# Exceptions — small graphics and animations ARE tracked
!assets/graphics/*.mp4
!assets/animations/*.mp4

# OS files
.DS_Store
Thumbs.db

# Credentials — NEVER commit
credentials.json
token.json
*.env
.env

# Work directories
work/
work_v3/
work_v4/
output/
runs/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Node
node_modules/
package-lock.json
